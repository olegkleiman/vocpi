{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
        "name": "Pytest Debug",
        "type": "debugpy",
        "request": "launch",
        "module": "pytest",
        "args": [
            "-v",
            "-s"
        ],
        "justMyCode": false
        },
        {
            "name": "Python: FastAPI",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "src.main:app",
                "--reload",
                "--host", "0.0.0.0",
                "--port", "8000"
            ],
            "env": {
                "LOG_LEVEL": "DEBUG"  // This is where you control it now
            },
            "jinja": true,
            "justMyCode": true
        }
    ]
}